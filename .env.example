# ─────────────────────────────────────────────────────────────────────────────
# My Galli environment variables.  Copy to `.env` for local dev; set the
# production values in the Vercel dashboard (Project → Settings → Environment
# Variables) for the Production environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL, used by Prisma) ──  REQUIRED
# Local dev: the Docker Postgres on port 5434. Use 127.0.0.1, NOT localhost
#   (Node resolves localhost to IPv6 ::1 where the container isn't reachable).
# Production: your managed Postgres (Neon / Supabase / Vercel Postgres) connection string.
DATABASE_URL="postgresql://pages:pages@127.0.0.1:5434/pages"
# Direct (non-pooled) connection used by Prisma for MIGRATIONS. On Vercel/Neon this
# is auto-provided; locally set it to the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://pages:pages@127.0.0.1:5434/pages"

# ── Auth (JWT) ──  REQUIRED
# MUST be a long, unique, random secret in production (the app refuses the placeholder value).
#   generate: openssl rand -base64 48
JWT_SECRET="change-this-to-a-long-random-secret"

# ── App URL ──  REQUIRED
# Drives canonical URLs, the sitemap, and OG/share links. No trailing slash.
# Production: https://mygalli.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── File storage (Vercel Blob) ──  REQUIRED in production (uploads; dev falls back to local disk)
# Vercel Dashboard → Storage → Create Blob Store. Works from any host, not just Vercel.
# The app also auto-detects Vercel's prefixed name (e.g. BLOB1_READ_WRITE_TOKEN)
# when the Blob integration collides on the BLOB_ prefix — see src/lib/storage-env.ts.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Rate limiting (Upstash Redis) ──  STRONGLY RECOMMENDED on Vercel
# On Vercel's serverless model the in-memory fallback does NOT share state across
# instances, so rate limits are per-instance (weak). Set these for real, shared limits.
# Upstash Dashboard → Create Redis Database (free tier is fine).
# The app also accepts Vercel's KV integration names (KV_REST_API_URL /
# KV_REST_API_TOKEN), which point at the same Upstash REST endpoint.
# UPSTASH_REDIS_REST_URL="https://...upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# ── Email (Resend) ──  Optional (verification/reset links log to the server console if unset)
# https://resend.com/api-keys — and verify a sending domain at resend.com for production
# (the default onboarding@resend.dev only delivers to the Resend account owner).
# RESEND_API_KEY="re_..."
# EMAIL_FROM="My Galli <noreply@mygalli.com>"

# ── Google sign-in (Google Identity Services) ──  Optional (button hidden if unset)
# Google Cloud Console → Credentials → OAuth Client ID (Web). Add your origins.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="...apps.googleusercontent.com"

# ── AI page generation (Anthropic) ──  Optional (only the /api/generate feature)
# ANTHROPIC_API_KEY="sk-ant-..."
