# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pages?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File Storage (Vercel Blob — required for production, optional for local dev)
# Get from: Vercel Dashboard → Storage → Create Blob Store
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Email (Resend — optional; verification/reset links log to the server console in dev if unset)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Galli <onboarding@resend.dev>"
